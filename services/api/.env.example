# =============================================================================
# AgentForge API — 环境变量配置
# =============================================================================
# 使用方式：
#   本地开发：cp .env.example .env，修改本地专属值后 docker compose up
#   生产部署：直接在服务器上编辑 /opt/agentforge/.env
#
# 核心区别只有两个变量，其余保持默认即可：
#   AGENTFORGE_RUNNER_MODE  →  本地: docker  |  生产: eci
#   AGENTFORGE_NAS_DIR      →  本地: 不设    |  生产: /mnt/nas/hermes-home
# =============================================================================

# ---------------------------------------------------------------------------
# 基础配置
# ---------------------------------------------------------------------------

AGENTFORGE_HTTP_ADDR=:8080
AGENTFORGE_PUBLIC_BASE_URL=http://localhost:8080
AGENTFORGE_DATA_DIR=../../var
AGENTFORGE_SESSION_SECRET=dev-change-me

# ---------------------------------------------------------------------------
# Hermes Agent 运行时配置
# ---------------------------------------------------------------------------

# 镜像地址（默认开源镜像；生产建议推到自己 ACR 用私有镜像）
AGENTFORGE_HERMES_IMAGE=nousresearch/hermes-agent:v2026.6.5
AGENTFORGE_HERMES_MEMORY=500m
AGENTFORGE_HERMES_CPUS=0.5

# ---------------------------------------------------------------------------
# 模型配置（LLM 调用参数，传给 Hermes 容器）
# ---------------------------------------------------------------------------

AGENTFORGE_MODEL_DEFAULT=deepseek-v4-flash
AGENTFORGE_MODEL_PROVIDER=custom
AGENTFORGE_MODEL_BASE_URL=https://api.deepseek.com
AGENTFORGE_MODEL_API_KEY=sk-your-api-key-here
AGENTFORGE_MODEL_API_MODE=chat_completions

# ---------------------------------------------------------------------------
# 微信 iLink Bot 配置
# ---------------------------------------------------------------------------

AGENTFORGE_WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# ---------------------------------------------------------------------------
# Agent Runner 模式（docker / eci）
# ---------------------------------------------------------------------------
# docker — 本地 Docker 运行 Hermes 容器（默认）
# eci    — 阿里云弹性容器实例，适合生产环境
# =============================================================================
#  切换方式：取消下面一行注释并填写 ECI 配置即可
# =============================================================================

AGENTFORGE_RUNNER_MODE=docker

# ---------------------------------------------------------------------------
# Docker Runner 配置（仅 AGENTFORGE_RUNNER_MODE=docker 时生效）
# ---------------------------------------------------------------------------

# Docker named volume 名称，用于 API 和 Hermes 容器间共享 agent 数据。
# 本地无需修改；生产 Docker 模式一般也不改。
# AGENTFORGE_DOCKER_AGENTS_VOLUME=agentforge_agentforge-agents-data

# ---------------------------------------------------------------------------
# ECI Runner 配置（仅 AGENTFORGE_RUNNER_MODE=eci 时生效，全部必填）
# ---------------------------------------------------------------------------

# AGENTFORGE_ECI_REGION=cn-hangzhou
# AGENTFORGE_ECI_ACCESS_KEY_ID=LTAI5txxxxxxxxxxxxxx
# AGENTFORGE_ECI_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AGENTFORGE_ECI_SECURITY_GROUP_ID=sg-bp1xxxxxxxxxxxxxxxx
# AGENTFORGE_ECI_VSWITCH_ID=vsw-bp1xxxxxxxxxxxxxxxx

# 可选：镜像缓存 ID，加速 ECI 冷启动
# AGENTFORGE_ECI_IMAGE_CACHE_ID=imc-bp1xxxxxxxxxxxxxxxx

# 可选：弹性公网 IP，用于 ECI 出公网（调用微信/LLM API）
# AGENTFORGE_ECI_EIP_INSTANCE_ID=eip-bp1xxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# NAS 持久化存储（仅 ECI 模式生效）
# ---------------------------------------------------------------------------
# ECI 容器通过 NFS 挂载 NAS，数据在容器生命周期外持久化。
# NAS 路径 = /<NASPath>/<agentID>，每个 agent 独立子目录。

# AGENTFORGE_ECI_NAS_HOST=xxxxxxxxxx-vyb15.cn-hangzhou.nas.aliyuncs.com
# AGENTFORGE_ECI_NAS_PATH=/hermes-home
# AGENTFORGE_ECI_NAS_FILE_SYSTEM_ID=xxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# docker-compose 专用变量（不在 Go 代码中读取，仅 compose 文件使用）
# ---------------------------------------------------------------------------

# API/WEB 端口映射
# API_PORT=8080
# WEB_PORT=3000

# ---------------------------------------------------------------------------
# 自动休眠/唤醒（Agent idle sleep / wake）
# ---------------------------------------------------------------------------
# 启用后，闲置 Agent 自动销毁容器以节省 ECI 计费，用户发微信消息时自动唤醒。
# 需要单实例部署；多实例会使 SleepPoller/IdleDetector 产生竞态。

# AGENTFORGE_AUTO_SLEEP_ENABLED=false
# AGENTFORGE_IDLE_TIMEOUT=10
# AGENTFORGE_SLEEP_POLL_INTERVAL=5
# AGENTFORGE_IDLE_CHECK_INTERVAL=60
# AGENTFORGE_IDLE_HEARTBEAT_MISSES=3
# AGENTFORGE_WAKE_HEARTBEAT_TIMEOUT=60

# ---------------------------------------------------------------------------
# docker-compose 专用变量（不在 Go 代码中读取，仅 compose 文件使用）
# ---------------------------------------------------------------------------

# API/WEB 端口映射
# API_PORT=8080
# WEB_PORT=3000

# NAS 宿主机挂载路径（仅生产 ECI 模式使用）
# 本地不设 → compose 用 named volume agentforge-agents-data
# 生产设置 → compose 用 bind mount 共享 NAS 目录
# AGENTFORGE_NAS_DIR=/mnt/nas/hermes-home
