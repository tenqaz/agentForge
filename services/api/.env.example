AGENTFORGE_HTTP_ADDR=:8080
AGENTFORGE_PUBLIC_BASE_URL=http://localhost:8080
AGENTFORGE_DATA_DIR=../../var
AGENTFORGE_SESSION_SECRET=dev-change-me
AGENTFORGE_HERMES_IMAGE=nousresearch/hermes-agent:v2026.6.5
AGENTFORGE_HERMES_MEMORY=500m
AGENTFORGE_HERMES_CPUS=0.5
# Tencent iLink Bot API base URL. Defaults to the public production
# endpoint; override only for staging/mock environments. Must be an
# absolute URL beginning with http:// or https://.
AGENTFORGE_WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
# Hermes model configuration
AGENTFORGE_MODEL_DEFAULT=deepseek-v4-flash
AGENTFORGE_MODEL_PROVIDER=custom
AGENTFORGE_MODEL_BASE_URL=https://api.deepseek.com
AGENTFORGE_MODEL_API_KEY=sk-your-api-key-here
AGENTFORGE_MODEL_API_MODE=chat_completions

# Brevo transactional email configuration for registration verification codes.
# Get the API key from Brevo: SMTP & API > API Keys (v3).
# The sender email/name must match a verified sender configured in Brevo.
# Without these the registration email-code endpoint returns email_send_failed.
AGENTFORGE_BREVO_API_KEY=xkeysib-your-brevo-api-key-here
AGENTFORGE_BREVO_SENDER_EMAIL=noreply@yourdomain.com
AGENTFORGE_BREVO_SENDER_NAME=AgentForge
# Optional override of the Brevo API base URL (default: https://api.brevo.com).
# AGENTFORGE_BREVO_BASE_URL=https://api.brevo.com

# Cloudflare Turnstile human verification for login & registration.
# Get sitekey/secret from the Cloudflare dashboard (Turnstile > widget).
# Both must be configured together; leaving SECRET empty disables Turnstile
# (frontend won't render the widget, backend won't verify tokens).
# The sitekey is served to the frontend via GET /api/turnstile/config.
AGENTFORGE_TURNSTILE_SECRET=1x0000000000000000000000000000000AA
AGENTFORGE_TURNSTILE_SITEKEY=1x00000000000000000000AA
# Optional override of the siteverify endpoint.
# AGENTFORGE_TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
# Optional hostname check. Unset → derived from AGENTFORGE_PUBLIC_BASE_URL;
# set to "none" to skip hostname verification (e.g. local dev with test sitekey).
AGENTFORGE_TURNSTILE_EXPECTED_HOSTNAME=none

# Agent runner mode: "docker" (default) or "eci" (Alibaba Cloud Elastic Container Instance).
# When set to "eci", the ECI_* settings below are required.
AGENTFORGE_RUNNER_MODE=docker

# Alibaba Cloud ECI credentials and network configuration.
# These are only used when AGENTFORGE_RUNNER_MODE=eci.
# AGENTFORGE_ECI_REGION=cn-hangzhou
# AGENTFORGE_ECI_ACCESS_KEY_ID=your-access-key-id
# AGENTFORGE_ECI_ACCESS_KEY_SECRET=your-access-key-secret
# AGENTFORGE_ECI_SECURITY_GROUP_ID=sg-xxxxxxxx
# AGENTFORGE_ECI_VSWITCH_ID=vsw-xxxxxxxx
# AGENTFORGE_ECI_IMAGE_CACHE_ID=imc-xxxxxxxx
